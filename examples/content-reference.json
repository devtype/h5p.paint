{
  "taskDescription": "<p>Draw a simple house with a door and two windows. Compare your drawing to the reference after submitting.</p>",
  "media": {
    "alternativeText": "Drawing area for a house sketch"
  },
  "canvas": {
    "width": 800,
    "aspectRatio": "1:1",
    "background": {
      "type": "color",
      "color": "#ffffff"
    },
    "tools": {
      "preset": "custom",
      "defaultTool": "line",
      "drawing": {
        "pencil": true,
        "brush": false,
        "eraser": true,
        "line": true,
        "rect": true,
        "ellipse": false,
        "text": false
      },
      "controls": {
        "color": true,
        "size": true
      },
      "actions": {
        "undo": true,
        "redo": true,
        "clear": true
      }
    },
    "brushDefaults": {
      "defaultColor": "#1f6feb",
      "defaultBrushSize": 4
    }
  },
  "behaviour": {
    "enableSubmit": true,
    "enableSolution": true,
    "enableRetry": true,
    "lockAfterSubmit": true,
    "scoringMode": "completion",
    "maxScore": 1
  }
}
