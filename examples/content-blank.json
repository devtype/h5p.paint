{
  "taskDescription": "<p>Draw anything you like on the blank canvas below.</p>",
  "media": {
    "alternativeText": "Blank drawing canvas"
  },
  "canvas": {
    "width": 800,
    "aspectRatio": "4:3",
    "background": {
      "type": "color",
      "color": "#ffffff"
    },
    "tools": {
      "preset": "sketch",
      "defaultTool": "pencil"
    },
    "brushDefaults": {
      "defaultColor": "#222222",
      "defaultBrushSize": 4,
      "colorMode": "palette",
      "paletteColors": [
        { "color": "#e11d48" },
        { "color": "#ea580c" },
        { "color": "#ca8a04" },
        { "color": "#16a34a" },
        { "color": "#2563eb" },
        { "color": "#7c3aed" }
      ]
    }
  },
  "behaviour": {
    "enableSubmit": true,
    "enableSolution": false,
    "enableRetry": true,
    "lockAfterSubmit": true,
    "scoringMode": "manual",
    "maxScore": 1
  }
}
