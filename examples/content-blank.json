{
  "taskDescription": "<p>Draw anything you like on the blank canvas below.</p>",
  "media": {
    "alternativeText": "Blank drawing canvas"
  },
  "canvas": {
    "width": 800,
    "aspectRatio": "4:3",
    "background": {
      "type": "color",
      "color": "#ffffff"
    },
    "tools": {
      "preset": "sketch",
      "defaultTool": "pencil"
    },
    "brushDefaults": {
      "defaultColor": "#222222",
      "defaultBrushSize": 4,
      "colorMode": "palette",
      "paletteColors": [
        "#e11d48",
        "#ea580c",
        "#ca8a04",
        "#16a34a",
        "#2563eb"
      ]
    }
  },
  "behaviour": {
    "enableSubmit": true,
    "enableSolution": false,
    "enableRetry": true,
    "lockAfterSubmit": true,
    "scoringMode": "manual",
    "maxScore": 1
  }
}
