[
  {
    "name": "taskDescription",
    "label": "Task description",
    "description": "Prompt shown above the drawing canvas. May contain HTML.",
    "type": "text",
    "widget": "html",
    "importance": "high",
    "default": "<p>Draw your answer below.</p>",
    "enterMode": "p",
    "tags": [
      "strong",
      "em",
      "u",
      "a",
      "ul",
      "ol",
      "h2",
      "h3",
      "hr",
      "pre",
      "code"
    ]
  },
  {
    "name": "media",
    "type": "group",
    "label": "Media",
    "importance": "medium",
    "expanded": true,
    "fields": [
      {
        "name": "referenceImage",
        "type": "image",
        "label": "Reference / solution image",
        "description": "Optional image revealed when the learner clicks 'Show solution'. Use this to show the expected drawing.",
        "optional": true
      },
      {
        "name": "alternativeText",
        "type": "text",
        "label": "Drawing alternative text",
        "description": "Describes the canvas for screen reader users. Empty falls back to the task description.",
        "optional": true
      }
    ]
  },
  {
    "name": "canvas",
    "type": "group",
    "label": "Canvas options",
    "importance": "medium",
    "expanded": false,
    "fields": [
      {
        "name": "width",
        "type": "number",
        "label": "Canvas base width (px)",
        "description": "The canvas scales responsively but uses this value to set its internal aspect. Very large values produce bigger PNG exports and xAPI attachments.",
        "default": 800,
        "min": 200,
        "max": 4000
      },
      {
        "name": "aspectRatio",
        "type": "select",
        "label": "Aspect ratio",
        "default": "4:3",
        "options": [
          { "value": "4:3", "label": "4:3" },
          { "value": "16:9", "label": "16:9" },
          { "value": "1:1", "label": "1:1 (square)" },
          { "value": "3:4", "label": "3:4 (portrait)" },
          { "value": "background", "label": "Match background image" }
        ]
      },
      {
        "name": "background",
        "type": "group",
        "label": "Background",
        "importance": "medium",
        "expanded": true,
        "fields": [
          {
            "name": "type",
            "type": "select",
            "label": "Background type",
            "default": "color",
            "options": [
              { "value": "color", "label": "Solid color" },
              { "value": "image", "label": "Image" }
            ]
          },
          {
            "name": "color",
            "type": "text",
            "label": "Background color",
            "description": "Used when background type is Solid color.",
            "default": "#ffffff",
            "widget": "showWhen",
            "showWhen": {
              "rules": [
                { "field": "type", "equals": "color" }
              ],
              "widget": "colorSelector"
            }
          },
          {
            "name": "image",
            "type": "image",
            "label": "Background image",
            "description": "Used when background type is Image (e.g. graph paper, photo to annotate).",
            "optional": true,
            "widget": "showWhen",
            "showWhen": {
              "rules": [
                { "field": "type", "equals": "image" }
              ]
            }
          }
        ]
      },
      {
        "name": "tools",
        "type": "group",
        "label": "Available tools",
        "description": "Choose which tools learners see in the toolbar. Enable at least one drawing tool.",
        "importance": "medium",
        "expanded": true,
        "fields": [
          { "name": "pencil", "type": "boolean", "label": "Pencil", "default": true },
          { "name": "brush", "type": "boolean", "label": "Brush", "default": true },
          { "name": "eraser", "type": "boolean", "label": "Eraser", "default": true },
          { "name": "line", "type": "boolean", "label": "Line", "default": true },
          { "name": "rect", "type": "boolean", "label": "Rectangle", "default": true },
          { "name": "ellipse", "type": "boolean", "label": "Ellipse", "default": true },
          { "name": "text", "type": "boolean", "label": "Text", "default": true },
          { "name": "color", "type": "boolean", "label": "Color picker", "default": true },
          { "name": "size", "type": "boolean", "label": "Brush size", "default": true },
          { "name": "undo", "type": "boolean", "label": "Undo", "default": true },
          { "name": "redo", "type": "boolean", "label": "Redo", "default": true },
          { "name": "clear", "type": "boolean", "label": "Clear", "default": true }
        ]
      },
      {
        "name": "brushDefaults",
        "type": "group",
        "label": "Brush defaults",
        "importance": "medium",
        "expanded": false,
        "fields": [
          {
            "name": "defaultColor",
            "type": "text",
            "label": "Default brush color",
            "default": "#222222",
            "widget": "colorSelector"
          },
          {
            "name": "defaultBrushSize",
            "type": "number",
            "label": "Default brush size (px)",
            "default": 4,
            "min": 1,
            "max": 60
          }
        ]
      }
    ]
  },
  {
    "name": "behaviour",
    "type": "group",
    "label": "Behavioural settings",
    "importance": "low",
    "expanded": false,
    "fields": [
      {
        "name": "enableSubmit",
        "type": "boolean",
        "label": "Enable submit button",
        "default": true
      },
      {
        "name": "enableSolution",
        "type": "boolean",
        "label": "Enable 'Show solution' button",
        "description": "Only effective if a reference image is configured.",
        "default": true
      },
      {
        "name": "enableRetry",
        "type": "boolean",
        "label": "Enable 'Retry' button",
        "default": true
      },
      {
        "name": "lockAfterSubmit",
        "type": "boolean",
        "label": "Lock canvas after submit",
        "description": "Prevents further editing once the drawing has been submitted (until retry).",
        "default": true
      },
      {
        "name": "scoringMode",
        "type": "select",
        "label": "Scoring mode",
        "default": "manual",
        "options": [
          {
            "value": "manual",
            "label": "Manual (teacher / host evaluates)"
          },
          {
            "value": "completion",
            "label": "Completion (full score when submitted with a drawing)"
          },
          {
            "value": "ai",
            "label": "AI (grade drawing via configured endpoint)"
          }
        ]
      },
      {
        "name": "aiGrading",
        "type": "group",
        "label": "AI grading",
        "importance": "medium",
        "expanded": true,
        "widget": "showWhen",
        "showWhen": {
          "rules": [
            { "field": "scoringMode", "equals": "ai" }
          ]
        },
        "fields": [
          {
            "name": "endpointUrl",
            "type": "text",
            "label": "Grading endpoint URL",
            "description": "POST endpoint that accepts the learner drawing and returns a JSON score. Ignored when the host provides H5PIntegration.paintAiGrader. Learner drawings and task metadata may be transmitted to this URL; ensure you have a legal basis and privacy notice before using an external service. See docs/PRIVACY.md.",
            "optional": true
          },
          {
            "name": "rubric",
            "type": "text",
            "label": "Grading rubric",
            "description": "Optional criteria sent to the grading service (plain text or HTML).",
            "optional": true,
            "widget": "html",
            "enterMode": "p",
            "tags": ["strong", "em", "ul", "ol"]
          },
          {
            "name": "includeReferenceImage",
            "type": "boolean",
            "label": "Include reference image URL in grading request",
            "default": true
          },
          {
            "name": "requestTimeoutMs",
            "type": "number",
            "label": "Request timeout (ms)",
            "default": 30000,
            "min": 1000,
            "max": 120000
          },
          {
            "name": "maxExportWidth",
            "type": "number",
            "label": "Max PNG width sent to grader (px)",
            "description": "Learner drawings are downscaled to this width before grading requests. Lower values reduce payload size and API cost.",
            "default": 1024,
            "min": 256,
            "max": 4096
          },
          {
            "name": "showFeedbackToLearner",
            "type": "boolean",
            "label": "Show AI feedback to learner",
            "default": true
          },
          {
            "name": "showConfidenceToLearner",
            "type": "boolean",
            "label": "Show AI confidence to learner",
            "description": "When the grader returns a confidence value (0–1), display it in the feedback panel.",
            "default": false
          },
          {
            "name": "onFailure",
            "type": "select",
            "label": "If grading fails",
            "default": "zero",
            "options": [
              { "value": "zero", "label": "Award 0 points" },
              { "value": "completion", "label": "Award full score (like completion mode)" },
              { "value": "manual", "label": "Award 0 points (manual review)" }
            ]
          }
        ]
      },
      {
        "name": "maxScore",
        "type": "number",
        "label": "Maximum score",
        "description": "Maximum points for this question. Manual: learner score stays 0 until evaluated. Completion: full score after submit. AI: score returned by the grading service.",
        "default": 1,
        "min": 0,
        "max": 100
      }
    ]
  },
  {
    "name": "l10n",
    "type": "group",
    "label": "User interface translations",
    "common": true,
    "importance": "low",
    "expanded": false,
    "fields": [
      { "name": "submit", "type": "text", "label": "Submit", "default": "Submit" },
      { "name": "showSolution", "type": "text", "label": "Show solution", "default": "Show solution" },
      { "name": "hideSolution", "type": "text", "label": "Hide solution", "default": "Hide solution" },
      { "name": "retry", "type": "text", "label": "Retry", "default": "Retry" },
      { "name": "submitted", "type": "text", "label": "Submitted message", "default": "Your drawing has been submitted." },
      { "name": "noDrawing", "type": "text", "label": "No drawing yet", "default": "Please draw something before submitting." },
      { "name": "solutionTitle", "type": "text", "label": "Solution title", "default": "Reference" },
      { "name": "yourDrawingTitle", "type": "text", "label": "Your drawing title", "default": "Your drawing" },
      { "name": "aiGrading", "type": "text", "label": "Grading in progress", "default": "Your drawing is being graded…" },
      { "name": "aiGradingFailed", "type": "text", "label": "Grading failed message", "default": "Automatic grading could not be completed." },
      { "name": "aiFeedbackTitle", "type": "text", "label": "AI feedback title", "default": "Feedback" },
      { "name": "aiScoreLabel", "type": "text", "label": "AI score label", "default": "Score" },
      { "name": "aiConfidenceLabel", "type": "text", "label": "AI confidence label", "default": "Confidence" },
      { "name": "aiGradingInterrupted", "type": "text", "label": "Grading interrupted message", "default": "Grading was interrupted. Please submit again." }
    ]
  },
  {
    "name": "a11y",
    "type": "group",
    "label": "Accessibility translations",
    "common": true,
    "importance": "low",
    "expanded": false,
    "fields": [
      { "name": "canvasLabel", "type": "text", "label": "Canvas label", "default": "Drawing area" },
      { "name": "toolbarLabel", "type": "text", "label": "Toolbar label", "default": "Drawing tools" },
      { "name": "tool_pencil", "type": "text", "label": "Pencil", "default": "Pencil" },
      { "name": "tool_brush", "type": "text", "label": "Brush", "default": "Brush" },
      { "name": "tool_eraser", "type": "text", "label": "Eraser", "default": "Eraser" },
      { "name": "tool_line", "type": "text", "label": "Line", "default": "Line" },
      { "name": "tool_rect", "type": "text", "label": "Rectangle", "default": "Rectangle" },
      { "name": "tool_ellipse", "type": "text", "label": "Ellipse", "default": "Ellipse" },
      { "name": "tool_text", "type": "text", "label": "Text", "default": "Add text" },
      { "name": "tool_color", "type": "text", "label": "Color", "default": "Color" },
      { "name": "tool_size", "type": "text", "label": "Brush size", "default": "Brush size" },
      { "name": "tool_undo", "type": "text", "label": "Undo", "default": "Undo" },
      { "name": "tool_redo", "type": "text", "label": "Redo", "default": "Redo" },
      { "name": "tool_clear", "type": "text", "label": "Clear", "default": "Clear canvas" },
      { "name": "solutionShown", "type": "text", "label": "Solution shown", "default": "Reference solution shown." },
      { "name": "solutionHidden", "type": "text", "label": "Solution hidden", "default": "Reference solution hidden." }
    ]
  }
]
